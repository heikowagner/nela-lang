-- NELA v0.10 — Wolfenstein raycaster + score tracking
--
-- v0.10 (NEW):
--   + build_minimap()       — compute 8×8 grid showing walls/player
--   + doors_count tracking  — increment when door successfully opened
--   + steps_count tracking  — increment on each forward/back/turn movement
--   + game_loop returns     — [frame, doors_opened, steps_taken, minimap]
--   Mission: All game logic stays in NELA-S. Python is I/O-only.
--
-- v0.9 vs v0.8:
--   + io_key token        — read a keypress through a linear I/O token
--   + io_print frame tok  — print a frame, return new token
--   + key_action c        — map char → action code (NELA-S, not Python)
--   + game_loop state map w token  — full game loop in NELA-S
--   Python harness now only provides: _getch callback, _print_frame callback
--
-- v0.8 vs v0.7:
--   + array n v  — create list of n elements all equal to v
--   + aset arr i v  — functional update: return new list with index i set to v
--   + len arr    — list length
--   + use_door state map w  — open the wall directly in front of the player
--
-- Coordinate system:
--   Positions: float, 1 unit = 1 grid cell.
--   Angles:    integers 0..359 degrees.
--   angle 0  → south (+y), 90 → east (+x), 180 → north (-y), 270 → west (-x)
--
-- State: [px, py, angle]  (px,py floats, angle int)

-- ── Trig utilities ────────────────────────────────────────────────────────────

-- pi/180 as a float literal
def deg_to_rad a = a * 0.017453292519943295

-- Normalize integer angle to [0, 359]
def norm_angle a =
  if a >= 360 then norm_angle (a - 360)
  else if a < 0 then norm_angle (a + 360)
  else a

-- ── Map primitives ────────────────────────────────────────────────────────────

def map_get map idx = get map idx

-- is_wall takes float x,y: floor to grid cell first
def is_wall map x y w = map_get map ((floor x) + (floor y) * w)

-- ── State accessors  state = [px, py, angle] ─────────────────────────────────

def state_px    state = head state
def state_py    state = head (tail state)
def state_angle state = head (tail (tail state))

-- ── Fixed-point ray marcher ───────────────────────────────────────────────────
--
-- Positions in cell units (float).  Step size: 0.05 cells.
-- Returns step count to first wall (limit = max steps, typically 400).

def ray_march map w rx ry dx dy limit =
  if limit == 0 then 400
  else
    if is_wall map rx ry w == 1 then 0
    else 1 + ray_march map w (rx + dx) (ry + dy) dx dy (limit - 1)

-- ── Single column rendering ───────────────────────────────────────────────────
--
-- Wall height = floor(21 / ((dist + 1) * 0.05))
-- At 1 cell (dist≈20): height ≈ 20 rows.  At 5 cells (dist≈100): ≈ 4 rows.

def render_col map w px py ray_angle =
  let a    = norm_angle ray_angle in
  let rad  = deg_to_rad a in
  let dx   = sin rad * 0.05 in
  let dy   = cos rad * 0.05 in
  let dist = ray_march map w px py dx dy 400 in
  floor (21.0 / ((dist + 1) * 0.05))

-- ── All columns (col_idx starts at 0) ────────────────────────────────────────

def render_cols map w px py angle half_fov ncols col_idx =
  if col_idx == ncols then []
  else
    let ray_angle = angle - half_fov + col_idx in
    let h = render_col map w px py ray_angle in
    h :: render_cols map w px py angle half_fov ncols (col_idx + 1)

-- ── Frame assembly ────────────────────────────────────────────────────────────
-- (unchanged from v0.5 — returns shade integers 0=ceil,1=floor,2-4=wall)

def shade_of h screen_h =
  let q3 = screen_h * 3 / 4 in
  let q2 = screen_h / 2     in
  if h >= q3 then 4
  else if h >= q2 then 3
  else 2

def frame_cell row col_h mid screen_h =
  let half = col_h / 2 in
  let dist = if row >= mid then row - mid else mid - row in
  if dist <= half then shade_of col_h screen_h
  else if row < mid then 0
  else 1

def cap h limit =
  if h > limit then limit else h

def frame_row heights row mid screen_h =
  match heights
  | [] = []
  | h::t =
    let ch = cap h screen_h in
    frame_cell row ch mid screen_h :: frame_row t row mid screen_h

def make_frame heights screen_h row =
  if row == screen_h then []
  else
    let mid = screen_h / 2 in
    frame_row heights row mid screen_h :: make_frame heights screen_h (row + 1)

-- render_frame: one call returns a complete list-of-rows of shade integers.
-- No trig tables needed — sin/cos computed directly.

def render_frame map w px py angle half_fov ncols screen_h =
  let heights = render_cols map w px py angle half_fov ncols 0 in
  make_frame heights screen_h 0

-- ── Movement with collision detection ────────────────────────────────────────

def try_move map w nx ny old_px old_py angle =
  if is_wall map nx ny w == 1
  then old_px :: old_py :: angle :: []
  else nx :: ny :: angle :: []

def move_forward map w state speed =
  let px  = state_px    state in
  let py  = state_py    state in
  let a   = state_angle state in
  let rad = deg_to_rad a in
  let nx  = px + sin rad * speed in
  let ny  = py + cos rad * speed in
  try_move map w nx ny px py a

def move_back map w state speed =
  let px  = state_px    state in
  let py  = state_py    state in
  let a   = state_angle state in
  let rad = deg_to_rad a in
  let nx  = px - sin rad * speed in
  let ny  = py - cos rad * speed in
  try_move map w nx ny px py a

def turn state delta =
  let px = state_px    state in
  let py = state_py    state in
  let a  = state_angle state in
  px :: py :: norm_angle (a + delta) :: []

-- ── Game update ───────────────────────────────────────────────────────────────
--
-- key: 0 = forward   1 = backward   2 = turn-left   3 = turn-right
-- No trig tables in signature: sin/cos computed directly inside move_*.

def update state key map w =
  if key == 0 then move_forward map w state 0.2
  else if key == 1 then move_back  map w state 0.2
  else if key == 2 then turn state (-5)
  else if key == 3 then turn state 5
  else state

-- ── Door / cell mutation (v0.8) ──────────────────────────────────────────────
--
-- Open (remove) the wall cell directly in front of the player.
-- Returns the updated map.  Caller stores the new map alongside state.
-- 'e' key in wolf_player.py triggers this; non-wall cells are a no-op.

def use_door state map w =
  let px  = state_px    state in
  let py  = state_py    state in
  let a   = state_angle state in
  let rad = deg_to_rad a in
  let tx  = floor (px + sin rad) in
  let ty  = floor (py + cos rad) in
  if is_wall map tx ty w == 1
  then aset map (tx + ty * w) 0
  else map

-- ── Key mapping (v0.9) ──────────────────────────────────────────────────────
--
-- Maps raw char → action code:
--   0 = forward  1 = backward  2 = turn-left  3 = turn-right
--   4 = door     5 = quit      6 = unknown

def key_action c =
  if c == 'w' then 0
  else if c == 'W' then 0
  else if c == 's' then 1
  else if c == 'S' then 1
  else if c == 'a' then 2
  else if c == 'A' then 2
  else if c == 'd' then 3
  else if c == 'D' then 3
  else if c == 'e' then 4
  else if c == 'E' then 4
  else if c == 'q' then 5
  else if c == 'Q' then 5
  else 6

-- ── Minimap generation (v0.9+) ─────────────────────────────────────────────
-- Minimap is an 8×8 grid where:
--   0 = open space
--   1 = wall
--   2 = player location

def minimap_cell map w px py grid_x grid_y =
  let px_floor = floor px in
  let py_floor = floor py in
  let cell_val = get map (grid_x + grid_y * w) in
  if grid_x == px_floor then
    if grid_y == py_floor then 2
    else if cell_val == 1 then 1
    else 0
  else if cell_val == 1 then 1
  else 0

def minimap_row map w px py grid_y col =
  if col == w then []
  else
    let cell = minimap_cell map w px py col grid_y in
    cell :: minimap_row map w px py grid_y (col + 1)

def build_minimap map w px py row =
  if row == w then []
  else
    let row_cells = minimap_row map w px py row 0 in
    row_cells :: build_minimap map w px py (row + 1)

-- ── IOToken-based game loop with stats (v0.9+) ───────────────────────────────
--
-- Returns: [frame, doors_opened, steps_count, minimap]
-- token consumed/produced internally; game_loop interface hides IOToken linearity

def game_loop_rec state map w doors steps token =
  let frame  = render_frame map w (get state 0) (get state 1) (get state 2) 20 40 21 in
  let tok1   = io_print frame token in
  let kpair  = io_key tok1 in
  let c      = fst kpair in
  let tok2   = snd kpair in
  let action = key_action c in
  if action == 5 then
    let minimap = build_minimap map w (get state 0) (get state 1) 0 in
    [frame, doors, steps, minimap]
  else
    let px_pos = get state 0 in
    let py_pos = get state 1 in
    let angle_pos = get state 2 in
    let rad_angle = deg_to_rad angle_pos in
    let door_x = floor (px_pos + sin rad_angle) in
    let door_y = floor (py_pos + cos rad_angle) in
    let door_cell = is_wall map door_x door_y w in
    let map2 = if action == 4 then (if door_cell == 1 then use_door state map w else map) else map in
    let doors2 = if action == 4 then (if door_cell == 1 then doors + 1 else doors) else doors in
    let state2 = if action <= 3 then update state action map w else state in
    let steps2 = if action <= 3 then steps + 1 else steps in
    game_loop_rec state2 map2 w doors2 steps2 tok2

def game_loop state map w token =
  game_loop_rec state map w 0 0 token
