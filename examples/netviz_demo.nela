-- ── @SECTION_DEMO [16-23] ───────────────────────────────────────────────────
-- Functions: netviz_demo
-- Purpose: Small deterministic function suitable for interaction-net visualization
-- Called_by: examples/netviz_interaction_net.py
-- Key_vars: [xs, h, t]
-- Details: Produces sorted list with list metadata pair

def netviz_demo xs =
  match xs
  | []   = (0, [])
  | h::t =
      let left  = [x <- t | x <= h] in
      let right = [x <- t | x > h] in
      (1 + len t, left ++ [h] ++ right)
