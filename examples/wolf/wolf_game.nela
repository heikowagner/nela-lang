def wall_tex_id col =
  if col < 13 then 0
  else if col < 26 then 1
  else 2

def wrap16 n =
  if n >= 16 then wrap16 (n - 16)
  else if n < 0 then wrap16 (n + 16)
  else n

def tex_pick tex_id =
  if tex_id == 0 then tex_brick 0
  else if tex_id == 1 then tex_planks 0
  else tex_metal 0

def tex_sample tex_id u v =
  let tex = tex_pick tex_id in
  let row = get tex (wrap16 v) in
  get row (wrap16 u)

-- ── @SECTION_FRAME [242-300] ─────────────────────────────────────────────────
-- Functions: frame_cell, frame_row, make_frame, render_frame, cap
-- Purpose: Frame buffer assembly; map column data to 40x21 grid of shade IDs
-- Calls: render_cols_data, tex_sample, wall_tex_id, cap
-- Called_by: render_frame, game_loop_rec
-- Key_vars: [frame, row, col, shade_id, mid, screen_h, col_idx]
-- Details:
--   - frame_cell: determine shade ID for single pixel based on wall height + texture
--   - frame_row: render all pixels in one row
--   - make_frame: build full frame recursively row-by-row
--   - render_frame: orchestrate raycasting + frame assembly
--   - cap: clamp wall height to screen height

def cap h limit =
  if h > limit then limit else h

def frame_cell row col_h col_kind mid screen_h col_idx =
  let half = col_h / 2 in
  let dist = if row >= mid then row - mid else mid - row in
  if dist <= half then
    if col_kind == 1 then 5
    else tex_sample (wall_tex_id col_idx) col_idx row
  else if row < mid then 0
  else 1

def frame_row cols row mid screen_h col_idx =
  match cols
  | [] = []
  | c::t =
    let k = head c in
    let h = head (tail c) in
    let ch = cap h screen_h in
    frame_cell row ch k mid screen_h col_idx :: frame_row t row mid screen_h (col_idx + 1)

def make_frame cols screen_h row =
  if row == screen_h then []
  else
    let mid = screen_h / 2 in
    frame_row cols row mid screen_h 0 :: make_frame cols screen_h (row + 1)

-- render_frame: one call returns a complete list-of-rows of shade integers.
-- No trig tables needed — sin/cos computed directly.

def render_frame map w enemies px py angle half_fov ncols screen_h =
  let cols = render_cols_data map w enemies px py angle half_fov ncols 0 in
  make_frame cols screen_h 0

-- ── @SECTION_MOVEMENT [302-355] ──────────────────────────────────────────────
-- Functions: try_move, move_forward, move_back, turn
-- Purpose: Player movement with collision detection; rotation
-- Calls: state_px, state_py, state_angle, deg_to_rad, norm_angle, is_wall, sin, cos
-- Called_by: update
-- Key_vars: [nx, ny, speed, old_px, old_py, delta]
-- Details:
--   - try_move: check if (nx,ny) is walkable; return updated state or old state
--   - move_forward/move_back: compute delta from angle, call try_move
--   - turn: rotate angle by delta degrees, normalize to [0,359]
--   - collision: any wall check prevents move

def try_move map w nx ny old_px old_py angle =
  if is_wall map nx ny w == 1
  then old_px :: old_py :: angle :: []
  else nx :: ny :: angle :: []

def move_forward map w state speed =
  let px  = state_px    state in
  let py  = state_py    state in
  let a   = state_angle state in
  let rad = deg_to_rad a in
  let nx  = px + sin rad * speed in
  let ny  = py + cos rad * speed in
  try_move map w nx ny px py a

def move_back map w state speed =
  let px  = state_px    state in
  let py  = state_py    state in
  let a   = state_angle state in
  let rad = deg_to_rad a in
  let nx  = px - sin rad * speed in
  let ny  = py - cos rad * speed in
  try_move map w nx ny px py a

def turn state delta =
  let px = state_px    state in
  let py = state_py    state in
  let a  = state_angle state in
  px :: py :: norm_angle (a + delta) :: []

-- ── @SECTION_GAME [357-380] ───────────────────────────────────────────────────
-- Functions: update, key_action
-- Purpose: Player input handling; map actions to state updates
-- Calls: move_forward, move_back, turn, is_wall
-- Called_by: game_loop_rec
-- Key_vars: [action, key, state, map, w]
-- Details:
--   - key_action: char ('w','s','a','d','e','q') → action code (0-6)
--   - update: apply action to state with collision detection
--   - action codes: 0=fwd, 1=back, 2=left, 3=right, 4=door, 5=quit, 6=unknown

def update state key map w =
  if key == 0 then move_forward map w state 0.2
  else if key == 1 then move_back  map w state 0.2
  else if key == 2 then turn state (-5)
  else if key == 3 then turn state 5
  else state

def key_action c =
  if c == 'w' then 0
  else if c == 'W' then 0
  else if c == 's' then 1
  else if c == 'S' then 1
  else if c == 'a' then 2
  else if c == 'A' then 2
  else if c == 'd' then 3
  else if c == 'D' then 3
  else if c == 'e' then 4
  else if c == 'E' then 4
  else if c == 'q' then 5
  else if c == 'Q' then 5
  else 6

-- ── @SECTION_DOOR [382-395] ───────────────────────────────────────────────────
-- Functions: use_door
-- Purpose: Open (remove) wall cell directly in front of player
-- Calls: state_px, state_py, state_angle, deg_to_rad, floor, is_wall, aset
-- Called_by: game_loop_rec
-- Key_vars: [tx, ty, door_cell]
-- Details:
--   - target: cell directly ahead (computed from angle)
--   - if target is wall: set map cell to 0 (open)
--   - if not wall: no-op (returns same map)
--   - returns updated map (caller manages state separately)

def use_door state map w =
  let px  = state_px    state in
  let py  = state_py    state in
  let a   = state_angle state in
  let rad = deg_to_rad a in
  let tx  = floor (px + sin rad) in
  let ty  = floor (py + cos rad) in
  if is_wall map tx ty w == 1
  then aset map (tx + ty * w) 0
  else map

-- ── @SECTION_ENEMIES [397-470] ────────────────────────────────────────────────
-- Functions: enemy_x, enemy_y, enemy_alert, dist, enemy_step_toward, update_enemy, update_enemies, is_wall_fat, los_clear, enemy_visible, visible_enemies
-- Purpose: Enemy AI, collision, visibility testing; LOS checking
-- Calls: dist, is_wall, enemy_step_toward, los_clear, ray_march_kind (legacy)
-- Called_by: ray_march_kind, update_enemies, visible_enemies, game_loop_rec, minimap_cell
-- Key_vars: [ex, ey, al, nx, ny, px, py, tx, ty, alert, los, visible]
-- Details:
--   - enemy_x/y/alert: field accessors for [x, y, alert] tuple
--   - dist: euclidean distance between two points
--   - enemy_step_toward: move toward target; stop if wall blocking
--   - update_enemy: alert hysteresis (distance thresholds); chase if alert
--   - is_wall_fat: 5-point wall check (center + 4 neighbors) for conservative LOS
--   - los_clear: recursive point sampling along ray; return 1 if unobstructed
--   - enemy_visible: check if enemy is visible to player (LOS + distance)
--   - visible_enemies: filter enemy list to only those player can see
-- Enemy representation: [x, y, alert]
-- Minimap cell values: 0=open, 1=wall, 2=player, 3=enemy-alert, 4=enemy-idle

def enemy_x e = get e 0
def enemy_y e = get e 1
def enemy_alert e = get e 2

def dist x1 y1 x2 y2 =
  let dx = x2 - x1 in
  let dy = y2 - y1 in
  sqrt (dx * dx + dy * dy)

def enemy_step_toward map w ex ey tx ty speed =
  let d = dist ex ey tx ty in
  if d == 0 then ex :: ey :: []
  else
    let nx = ex + ((tx - ex) / d) * speed in
    let ny = ey + ((ty - ey) / d) * speed in
    if is_wall map nx ny w == 1 then ex :: ey :: []
    else nx :: ny :: []

def update_enemy enemy px py map w =
  let ex = enemy_x enemy in
  let ey = enemy_y enemy in
  let al = enemy_alert enemy in
  let d  = dist ex ey px py in
  let al2 = if d < 2.6 then 1 else if d > 3.4 then 0 else al in
  let pos = if al2 == 1 then enemy_step_toward map w ex ey px py 0.08 else ex :: ey :: [] in
  let nx = get pos 0 in
  let ny = get pos 1 in
  nx :: ny :: al2 :: []

def update_enemies enemies px py map w =
  match enemies
  | [] = []
  | e::t = update_enemy e px py map w :: update_enemies t px py map w

def is_wall_fat map w x y =
  if is_wall map x y w == 1 then 1
  else if is_wall map (x + 0.08) y w == 1 then 1
  else if is_wall map (x - 0.08) y w == 1 then 1
  else if is_wall map x (y + 0.08) w == 1 then 1
  else if is_wall map x (y - 0.08) w == 1 then 1
  else 0

def los_clear map w px py ex ey i n =
  if i >= n then 1
  else
    let t = i / n in
    let sx = px + (ex - px) * t in
    let sy = py + (ey - py) * t in
    if is_wall_fat map w sx sy == 1 then 0
    else los_clear map w px py ex ey (i + 1) n

def enemy_visible map w px py enemy =
  let ex = enemy_x enemy in
  let ey = enemy_y enemy in
  let d = dist px py ex ey in
  if d < 0.05 then 1
  else
    let n = floor (d * 8.0) + 8 in
    los_clear map w px py ex ey 1 n

def visible_enemies enemies map w px py =
  match enemies
  | [] = []
  | e::t =
    let rest = visible_enemies t map w px py in
    if enemy_visible map w px py e == 1 then e :: rest
    else rest

-- ── @SECTION_MINIMAP [472-510] ────────────────────────────────────────────────
-- Functions: enemy_cell, minimap_cell, minimap_row, build_minimap, init_enemies
-- Purpose: 8x8 minimap generation; overlay player/enemies/walls
-- Calls: enemy_x, enemy_y, enemy_alert, visible_enemies, floor, is_wall, get
-- Called_by: build_minimap (recursive), render_packet, game_loop_rec
-- Key_vars: [gx, gy, ec, cv, minimap_data, cell_type]
-- Details:
--   - enemy_cell: find enemy at grid cell (gx,gy); return cell code (0-4)
--   - minimap_cell: single cell: 0=open, 1=wall, 2=player, 3=enemy-alert, 4=enemy-idle
--   - minimap_row/build_minimap: recursive row-by-row assembly
--   - init_enemies: default enemy spawn list
-- Minimap cell encoding: 0=open, 1=wall, 2=player, 3=enemy-alert, 4=enemy-idle

def enemy_cell enemies gx gy =
  match enemies
  | [] = 0
  | e::t =
    let ex = floor (enemy_x e) in
    let ey = floor (enemy_y e) in
    if ex == gx then
      if ey == gy then if enemy_alert e == 1 then 3 else 4
      else enemy_cell t gx gy
    else enemy_cell t gx gy

def minimap_cell map w px py enemies gx gy =
  let pxf = floor px in
  let pyf = floor py in
  let ec  = enemy_cell enemies gx gy in
  let cv  = get map (gx + gy * w) in
  if pxf == gx then
    if gy == pyf then 2
    else if ec > 0 then ec
    else if cv == 1 then 1
    else 0
  else
    if ec > 0 then ec
    else if cv == 1 then 1
    else 0

def minimap_row map w px py enemies gy gx =
  if gx == w then []
  else
    minimap_cell map w px py enemies gx gy :: minimap_row map w px py enemies gy (gx + 1)

def build_minimap map w px py enemies gy =
  if gy == w then []
  else minimap_row map w px py enemies gy 0 :: build_minimap map w px py enemies (gy + 1)

def init_enemies =
  [
    [2.5, 2.5, 0],
    [5.5, 3.5, 0],
    [3.5, 5.5, 0]
  ]

-- ── @SECTION_MAIN [512-541] ───────────────────────────────────────────────────
-- Functions: render_packet, game_loop_rec, game_loop
-- Purpose: Render orchestration; main game loop; IOToken threading
-- Calls: render_frame, build_minimap, visible_enemies, update_enemies, update, use_door, key_action, io_print, io_key
-- Called_by: examples/wolf/src/wolf_player.py (entry point)
-- Key_vars: [packet, frame, minimap, state, map, enemies, doors, steps, tok, action]
-- Details:
--   - render_packet: assemble output packet [frame, minimap, visible_enemies, doors, steps, state]
--   - game_loop_rec: tail-recursive main loop; reads input, updates world, renders
--   - game_loop: entry point with initial enemies + stats setup
--   - IO model: linear IOToken threading (io_print/io_key callbacks from Python)
--   - termination: player presses 'q' key (action == 5)

def render_packet frame minimap enemies doors steps state =
  [frame, minimap, enemies, doors, steps, state]

-- ── IOToken-based game loop with stats + enemies (v0.11) ───────────────────

def game_loop_rec state map w enemies doors steps token =
  let px = get state 0 in
  let py = get state 1 in
  let a  = get state 2 in
  let frame   = render_frame map w enemies px py a 20 40 21 in
  let minimap = build_minimap map w px py enemies 0 in
  let visible = visible_enemies enemies map w px py in
  let packet  = render_packet frame minimap visible doors steps state in
  let tok1    = io_print packet token in
  let kpair   = io_key tok1 in
  let c       = fst kpair in
  let tok2    = snd kpair in
  let action  = key_action c in
  if action == 5 then packet
  else
    let rad_angle = deg_to_rad a in
    let door_x = floor (px + sin rad_angle) in
    let door_y = floor (py + cos rad_angle) in
    let door_cell = is_wall map door_x door_y w in
    let map2 = if action == 4 then (if door_cell == 1 then use_door state map w else map) else map in
    let doors2 = if action == 4 then (if door_cell == 1 then doors + 1 else doors) else doors in
    let state2 = if action <= 3 then update state action map2 w else state in
    let steps2 = if action <= 3 then steps + 1 else steps in
    let enemies2 = update_enemies enemies (get state2 0) (get state2 1) map2 w in
    game_loop_rec state2 map2 w enemies2 doors2 steps2 tok2

def game_loop state map w token =
  game_loop_rec state map w [[2.5, 2.5, 0], [5.5, 3.5, 0], [3.5, 5.5, 0]] 0 0 token
