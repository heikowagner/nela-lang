-- ============================================================================
-- NELA v0.11 — Wolfenstein raycaster + enemies + textures
-- LLM-OPTIMIZED SINGLE-FILE ARCHITECTURE
-- ============================================================================
-- 
-- SECTION INDEX FOR LLM NAVIGATION (auto-maintained):
--   SECTION_TRIG                 [ 51- 65]      deg_to_rad | norm_angle
--   SECTION_MAP                  [ 67- 80]      map_get | is_wall
--   SECTION_STATE                [ 82- 90]      state_px | state_py | state_angle
--   SECTION_RAYCASTING           [ 92-165]      ray_march | enemy_hit_point | ray_march_kind | render_col_data | render_cols_data
--   SECTION_TEXTURES             [167-240]      shade_of | tex_size | tex_brick | tex_planks | tex_metal | wall_tex_id | wrap16 | tex_pick | tex_sample
--   SECTION_FRAME                [242-300]      cap | frame_cell | frame_row | make_frame | render_frame
--   SECTION_MOVEMENT             [302-355]      try_move | move_forward | move_back | turn
--   SECTION_GAME                 [357-380]      update | key_action
--   SECTION_DOOR                 [382-395]      use_door
--   SECTION_ENEMIES              [397-470]      enemy_x | enemy_y | enemy_alert | dist | enemy_step_toward | update_enemy | update_enemies | is_wall_fat | los_clear | enemy_visible | visible_enemies
--   SECTION_MINIMAP              [472-510]      enemy_cell | minimap_cell | minimap_row | build_minimap | init_enemies
--   SECTION_MAIN                 [512-541]      render_packet | game_loop_rec | game_loop
--
-- ARCHITECTURE:
--   Mission: ALL game logic in NELA-S. Python is I/O-only (framebuffer + input).
--   State: [px, py, angle] (px,py floats; angle int [0,359])
--   Map: flat list, 1D index = x + y*w
--   Render Output: 40x21 grid of shade IDs [0-13]:
--     0=ceiling, 1=floor, 2-4=wall (shade), 5=enemy, 6-13=textured walls
--   I/O Model: IOToken linear threading (io_print/io_key callbacks)
--   Textures: 3x 16x16 quantized shade tables (brick/planks/metal)
--   Enemies: [x, y, alert] with LOS+patrol AI, rendering as red shade-5 pixels
--
-- INVARIANTS (LLM enforces when editing):
--   - All functions must be declared before use (no forward refs)
--   - All game logic stays in NELA-S (no Python sprite code)
--   - Texture lookups stay in frame_cell (no external rendering)
--   - Enemy LOS uses fat-wall checks is_wall_fat (not raycasting)
--   - Coordinates: floats for position, ints for grid indices, angles normalized [0,359]
--   - After edits, update the index comments above to match current line numbers
--
-- VERSION HISTORY:
--   v0.11: Enemies + minimap + textures + LLM-optimized header
--   v0.10: doors/steps tracking + render_packet
--   v0.9:  IOToken game_loop (all logic in NELA-S)
--   v0.8:  array/aset/use_door
--   v0.7:  raycasting baseline
--
-- COORDINATE SYSTEM:
--   Position:  float units (1 cell = 1.0)
--   Angles:    integer degrees [0, 359]
--     angle 0   → south (+y)
--     angle 90  → east  (+x)
--     angle 180 → north (-y)
--     angle 270 → west  (-x)

-- ── @SECTION_TRIG [51-65] ────────────────────────────────────────────────────
-- Functions: deg_to_rad, norm_angle
-- Purpose: Angle conversion (degrees ↔ radians); normalize angles to [0,359]
-- Called_by: render_col_data, move_forward, move_back, use_door, game_loop_rec
-- Key_vars: [a, rad]

-- pi/180 as a float literal
def deg_to_rad a = a * 0.017453292519943295

-- Normalize integer angle to [0, 359]
def norm_angle a =
  if a >= 360 then norm_angle (a - 360)
  else if a < 0 then norm_angle (a + 360)
  else a

-- ── @SECTION_MAP [67-80] ──────────────────────────────────────────────────────
-- Functions: map_get, is_wall
-- Purpose: Map cell access; terrain collision detection
-- Calls: get (builtin)
-- Called_by: ray_march, ray_march_kind, try_move, use_door, los_clear, is_wall_fat, visible_enemies, minimap_cell
-- Key_vars: [map, idx, x, y, w]

def map_get map idx = get map idx

-- is_wall takes float x,y: floor to grid cell first
def is_wall map x y w = map_get map ((floor x) + (floor y) * w)

-- ── @SECTION_STATE [82-90] ────────────────────────────────────────────────────
-- Functions: state_px, state_py, state_angle
-- Purpose: Extract player state fields: [px, py, angle]
-- Calls: head, tail (builtin)
-- Called_by: move_forward, move_back, turn, update, use_door, game_loop_rec
-- Key_vars: [state, px, py, angle]

def state_px    state = head state
def state_py    state = head (tail state)
def state_angle state = head (tail (tail state))

-- ── @SECTION_RAYCASTING [92-165] ─────────────────────────────────────────────
-- Functions: ray_march, ray_march_kind, enemy_hit_point, render_col_data, render_cols_data
-- Purpose: Core raycasting engine; wall/enemy hit detection; column rendering
-- Calls: is_wall, is_wall_fat, enemy_hit_point
-- Called_by: render_frame, visible_enemies (for LOS via ray_march_kind)
-- Key_vars: [rx, ry, dx, dy, limit, kind, dist, col_idx, half_fov]
-- Details:
--   - step size: 0.05 cells
--   - wall height formula: floor(21 / ((dist+1) * 0.05))
--   - enemy detection: distance < 0.22 from ray
--   - returns [kind, dist] where kind=0 (wall) or 1 (enemy)

-- Fixed-point ray marcher
-- Positions in cell units (float).  Step size: 0.05 cells.
-- Returns step count to first wall (limit = max steps, typically 400).

def ray_march map w rx ry dx dy limit =
  if limit == 0 then 400
  else
    if is_wall map rx ry w == 1 then 0
    else 1 + ray_march map w (rx + dx) (ry + dy) dx dy (limit - 1)

-- Wall height = floor(21 / ((dist + 1) * 0.05))
-- At 1 cell (dist≈20): height ≈ 20 rows.  At 5 cells (dist≈100): ≈ 4 rows.

def enemy_hit_point enemies x y =
  match enemies
  | [] = 0
  | e::t =
    if dist x y (enemy_x e) (enemy_y e) < 0.22 then 1
    else enemy_hit_point t x y

-- Returns [kind, dist_steps]
-- kind: 0=wall/background ray stop, 1=enemy hit before wall

def ray_march_kind map w enemies rx ry dx dy limit =
  if limit == 0 then 0 :: 400 :: []
  else
    if is_wall map rx ry w == 1 then 0 :: 0 :: []
    else
      if enemy_hit_point enemies rx ry == 1 then 1 :: 0 :: []
      else
        let r = ray_march_kind map w enemies (rx + dx) (ry + dy) dx dy (limit - 1) in
        let k = head r in
        let d = head (tail r) in
        k :: (d + 1) :: []

-- Returns [kind, height]
def render_col_data map w enemies px py ray_angle =
  let a    = norm_angle ray_angle in
  let rad  = deg_to_rad a in
  let dx   = sin rad * 0.05 in
  let dy   = cos rad * 0.05 in
  let hit  = ray_march_kind map w enemies px py dx dy 400 in
  let kind = head hit in
  let dist = head (tail hit) in
  let h    = floor (21.0 / ((dist + 1) * 0.05)) in
  kind :: h :: []

-- ── All columns (col_idx starts at 0) ────────────────────────────────────────

def render_cols_data map w enemies px py angle half_fov ncols col_idx =
  if col_idx == ncols then []
  else
    let ray_angle = angle - half_fov + col_idx in
    let c = render_col_data map w enemies px py ray_angle in
    c :: render_cols_data map w enemies px py angle half_fov ncols (col_idx + 1)

-- ── @SECTION_TEXTURES [167-240] ──────────────────────────────────────────────
-- Functions: shade_of, tex_brick, tex_planks, tex_metal, wall_tex_id, wrap16, tex_pick, tex_sample
-- Purpose: Texture data (16x16 quantized tables); texture sampling on walls
-- Calls: wrap16, tex_pick, get (builtin)
-- Called_by: frame_cell, tex_sample
-- Key_vars: [tex_id, u, v, shade, col_idx]
-- Details:
--   - shade_of: wall height to shade ID mapping (2-4 based on screen height)
--   - tex_brick/planks/metal: 16x16 arrays; each cell is shade ID 6-13
--   - wall_tex_id: map column index to texture ID (deterministic)
--   - wrap16: recursive modulo for safe negative/overflow handling
--   - tex_pick: select texture function by ID
--   - tex_sample: lookup shade from texture at (u,v) coordinates

-- Frame assembly: shade_of maps wall height to brightness levels
def shade_of h screen_h =
  let q3 = screen_h * 3 / 4 in
  let q2 = screen_h / 2     in
  if h >= q3 then 4
  else if h >= q2 then 3
  else 2

-- AUTO-GENERATED by examples/wolf/tools/build_wolf_textures.py
-- Source textures: ambientCG CC0 (Creative Commons Zero)
def tex_size = 16

